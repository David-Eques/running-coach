# Worker secrets, read by `wrangler dev` when copied to `.dev.vars`.
#
# To run locally: cp .dev.vars.example .dev.vars and fill in the values, then
# `npm run dev`.
# To deploy: set these on the Worker with `wrangler secret put NAME` (or in the
# Cloudflare dashboard under Worker > Settings > Variables and Secrets). The
# "Deploy to Cloudflare" button does NOT set them for you.

# Strava API app credentials. Create an app at https://www.strava.com/settings/api
# and paste the Client ID and Client Secret here. The Authorization Callback Domain
# in your Strava app must match the host of your deployed Worker (e.g.
# `running-coach.your-subdomain.workers.dev`).
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Shared secret between Claude Code and the Worker. Pick anything random and
# strong — `openssl rand -hex 32` generates a good one. You'll paste the same
# value when wiring the MCP into Claude Code.
MCP_BEARER_TOKEN=
